# EcoWoods API Configuration
# Copy this file to .env and update values for your environment.

APP_NAME=EcoWoods API
APP_VERSION=1.0.0
DEBUG=false

HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://ecowoods:ecowoods_secret@db:5432/ecowoods_db
DATABASE_URL_SYNC=postgresql+psycopg2://ecowoods:ecowoods_secret@db:5432/ecowoods_db

# JWT Secret - CHANGE THIS IN PRODUCTION
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]
